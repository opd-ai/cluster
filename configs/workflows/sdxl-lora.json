{
  "_comment": "SDXL + LoRA workflow. Set lora_name to your LoRA filename under loras/sdxl/.",
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sdxl/sd_xl_base_1.0.safetensors" }
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["4", 0],
      "clip": ["4", 1],
      "lora_name": "sdxl/my-lora.safetensors",
      "strength_model": 0.8,
      "strength_clip": 0.8
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "batch_size": 1, "height": 1024, "width": 1024 }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["10", 1], "text": "a photo of a cat in the style of my-lora" }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["10", 1], "text": "blurry, low quality" }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": 7.5, "denoise": 1.0,
      "latent_image": ["5", 0], "model": ["10", 0],
      "negative": ["7", 0], "positive": ["6", 0],
      "sampler_name": "dpmpp_2m", "scheduler": "karras",
      "seed": 42, "steps": 25
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "sdxl-lora", "images": ["8", 0] } }
}
