{
  "_comment": "Flux.1-schnell workflow — 4-step fast inference.",
  "1": { "class_type": "UNETLoader", "inputs": { "unet_name": "flux/flux1-schnell.safetensors", "weight_dtype": "default" } },
  "2": { "class_type": "DualCLIPLoader", "inputs": { "clip_name1": "clip/clip_l.safetensors", "clip_name2": "clip/t5xxl_fp16.safetensors", "type": "flux" } },
  "3": { "class_type": "VAELoader", "inputs": { "vae_name": "vae/ae.safetensors" } },
  "4": { "class_type": "EmptySD3LatentImage", "inputs": { "batch_size": 1, "height": 1024, "width": 1024 } },
  "5": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["2", 0], "text": "a photo of a cat" } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["2", 0], "text": "" } },
  "7": { "class_type": "KSamplerSelect", "inputs": { "sampler_name": "euler" } },
  "8": { "class_type": "BasicScheduler", "inputs": { "model": ["1", 0], "scheduler": "simple", "steps": 4, "denoise": 1.0 } },
  "9": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": { "noise": ["11", 0], "guider": ["10", 0], "sampler": ["7", 0], "sigmas": ["8", 0], "latent_image": ["4", 0] }
  },
  "10": { "class_type": "CFGGuider", "inputs": { "model": ["1", 0], "positive": ["5", 0], "negative": ["6", 0], "cfg": 1.0 } },
  "11": { "class_type": "RandomNoise", "inputs": { "noise_seed": 42 } },
  "12": { "class_type": "VAEDecode", "inputs": { "samples": ["9", 0], "vae": ["3", 0] } },
  "13": { "class_type": "SaveImage", "inputs": { "filename_prefix": "flux-schnell", "images": ["12", 0] } }
}
