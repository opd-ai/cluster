{
  "_comment": "img2img workflow (SDXL). Set denoise < 1.0 to control variation.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "sdxl/sd_xl_base_1.0.safetensors" } },
  "20": { "class_type": "LoadImage", "inputs": { "image": "input.png", "upload": "image" } },
  "21": { "class_type": "VAEEncode", "inputs": { "pixels": ["20", 0], "vae": ["4", 2] } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["4", 1], "text": "a photo of a cat" } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["4", 1], "text": "blurry, low quality" } },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": 7.5, "denoise": 0.6,
      "latent_image": ["21", 0], "model": ["4", 0],
      "negative": ["7", 0], "positive": ["6", 0],
      "sampler_name": "dpmpp_2m", "scheduler": "karras",
      "seed": 42, "steps": 20
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "img2img", "images": ["8", 0] } }
}
