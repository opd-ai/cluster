{
  "_comment": "Inpainting workflow (SDXL). Requires a mask image.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "sdxl/sd_xl_base_1.0.safetensors" } },
  "20": { "class_type": "LoadImage", "inputs": { "image": "input.png", "upload": "image" } },
  "22": { "class_type": "LoadImage", "inputs": { "image": "mask.png", "upload": "image" } },
  "23": { "class_type": "VAEEncodeForInpaint", "inputs": { "pixels": ["20", 0], "vae": ["4", 2], "mask": ["22", 0], "grow_mask_by": 6 } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["4", 1], "text": "fill the masked area naturally" } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["4", 1], "text": "blurry, low quality, artifacts" } },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": 8.0, "denoise": 1.0,
      "latent_image": ["23", 0], "model": ["4", 0],
      "negative": ["7", 0], "positive": ["6", 0],
      "sampler_name": "dpmpp_2m", "scheduler": "karras",
      "seed": 42, "steps": 30
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "inpaint", "images": ["8", 0] } }
}
