# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Two-node quickstart for opd-ai/cluster.
#
# Brings up:
#   control  — k3s server (4 CPU, 8 GB RAM)
#   worker1  — k3s agent  (4 CPU, 8 GB RAM)
#
# Requirements:
#   vagrant >= 2.3, VirtualBox >= 7.0 (or libvirt)
#   vagrant plugin install vagrant-hostmanager (optional but recommended)
#
# Usage:
#   vagrant up
#   vagrant ssh control -- make bootstrap up
#   vagrant ssh control -- make train   # trains a tiny model
#   vagrant ssh control -- make serve   # starts the gateway
#
# Expected total time: < 60 minutes on a modern laptop.

CONTROL_IP = "192.168.56.10"
WORKER_IP  = "192.168.56.11"

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  # ── Control node ──────────────────────────────────────────────────────────
  config.vm.define "control" do |ctl|
    ctl.vm.hostname = "control"
    ctl.vm.network "private_network", ip: CONTROL_IP
    ctl.vm.provider "virtualbox" do |vb|
      vb.name   = "cluster-control"
      vb.cpus   = 4
      vb.memory = 8192
    end
    ctl.vm.provision "shell", path: "provision-control.sh",
      env: {
        "CONTROL_IP" => CONTROL_IP,
        "WORKER_IP"  => WORKER_IP,
      }
  end

  # ── Worker node ───────────────────────────────────────────────────────────
  config.vm.define "worker1" do |wrk|
    wrk.vm.hostname = "worker1"
    wrk.vm.network "private_network", ip: WORKER_IP
    wrk.vm.provider "virtualbox" do |vb|
      vb.name   = "cluster-worker1"
      vb.cpus   = 4
      vb.memory = 8192
    end
    wrk.vm.provision "shell", path: "provision-worker.sh",
      env: {
        "CONTROL_IP" => CONTROL_IP,
      }
  end
end
